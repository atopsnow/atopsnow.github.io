---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="404">
  <Header slot="header" />
  <Footer slot="footer" />
  <div class="py-20 text-center">
    <h1 class="text-7xl font-semibold text-accent">404</h1>
    <p class="mt-4 text-zinc-500">页面不存在 · Page not found</p>
    <a href="/" class="mt-6 inline-block text-accent hover:underline">← 回首页 / Home</a>
  </div>
</BaseLayout>
