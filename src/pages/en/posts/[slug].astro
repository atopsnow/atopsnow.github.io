---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import { byLocale, sortByDate, isPublished, slugOf, counterpartSlug } from '../../../lib/posts';
import { localizedPath } from '../../../i18n/ui';

export async function getStaticPaths() {
  const all = await getCollection('blog', isPublished);
  const en = sortByDate(byLocale(all, 'en'));
  return en.map((post, i) => ({
    params: { slug: slugOf(post.id) },
    props: {
      id: post.id,
      prev: en[i + 1] ? { href: localizedPath(`/posts/${slugOf(en[i + 1].id)}`, 'en'), title: en[i + 1].data.title } : null,
      next: en[i - 1] ? { href: localizedPath(`/posts/${slugOf(en[i - 1].id)}`, 'en'), title: en[i - 1].data.title } : null,
    },
  }));
}

const { id, prev, next } = Astro.props;
const post = await getEntry('blog', id);
if (!post) throw new Error(`Post not found: ${id}`);
const { Content } = await render(post);

const all = await getCollection('blog', isPublished);
const zhSlug = counterpartSlug(all, id, 'zh');
const slug = slugOf(id);
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  locale="en"
  zhHref={zhSlug ? localizedPath(`/posts/${zhSlug}`, 'zh') : '/'}
  enHref={localizedPath(`/posts/${slug}`, 'en')}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>
