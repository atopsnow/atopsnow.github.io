---
import type { GetStaticPaths, Page } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { byLocale, sortByDate, isPublished } from '../../lib/posts';
import { useTranslations } from '../../i18n/ui';
import { POSTS_PER_PAGE } from '../../consts';

export const getStaticPaths = (async ({ paginate }) => {
  const all = await getCollection('blog', isPublished);
  const zh = sortByDate(byLocale(all, 'zh'));
  return paginate(zh, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

type Entry = Awaited<ReturnType<typeof getCollection<'blog'>>>[number];
const { page } = Astro.props as { page: Page<Entry> };
const t = useTranslations('zh');
---
<BaseLayout title={t('nav.posts')}>
  <Header slot="header" />
  <Footer slot="footer" />
  <h1 class="text-2xl font-bold">{t('nav.posts')}</h1>
  <section class="mt-6">
    {page.data.map((p) => (
      <PostCard id={p.id} title={p.data.title} description={p.data.description}
        pubDate={p.data.pubDate} tags={p.data.tags} locale="zh" />
    ))}
  </section>
  <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} locale="zh" />
</BaseLayout>
