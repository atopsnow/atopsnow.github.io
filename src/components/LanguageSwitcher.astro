---
import { getLocaleFromUrl } from '../i18n/ui';
interface Props { zhHref?: string; enHref?: string; }
const { zhHref = '/', enHref = '/en/' } = Astro.props;
const current = getLocaleFromUrl(Astro.url);
---
<div class="flex items-center gap-2 text-sm">
  <a href={zhHref} class={current === 'zh' ? 'font-semibold' : 'text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100'}>中</a>
  <span class="text-zinc-300 dark:text-zinc-600">/</span>
  <a href={enHref} class={current === 'en' ? 'font-semibold' : 'text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100'}>EN</a>
</div>
