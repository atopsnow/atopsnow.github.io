---
import { slugOf } from '../lib/posts';
import { localizedPath } from '../i18n/ui';
import type { Locale } from '../consts';
interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  locale: Locale;
}
const { id, title, description, pubDate, tags, locale } = Astro.props;
const href = localizedPath(`/posts/${slugOf(id)}`, locale);
const dateStr = pubDate.toISOString().slice(0, 10);
---
<article class="border-b border-zinc-100 py-6 dark:border-zinc-800/60">
  <h2 class="text-xl font-semibold">
    <a href={href} class="hover:underline">{title}</a>
  </h2>
  <p class="mt-1 text-sm text-zinc-500"><time datetime={dateStr}>{dateStr}</time></p>
  <p class="mt-2 text-zinc-600 dark:text-zinc-400">{description}</p>
  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a href={localizedPath(`/tags/${tag}`, locale)} class="rounded bg-zinc-100 px-2 py-0.5 text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">#{tag}</a>
      ))}
    </div>
  )}
</article>
